#!/usr/bin/env bash
set -euo pipefail

if [ -z "${DATA_DIR:-}" ]; then
  echo "ERROR: DATA_DIR is not set. Are you in the dev shell? (nix develop)" >&2
  exit 1
fi

source load-infra-env

API="http://localhost:8080"

# Create a sample file
TMPFILE=$(mktemp /tmp/engram-test-XXXXXX.txt)
echo "This is a test file for engram metadata extraction." > "$TMPFILE"
HASH="sha256:$(sha256sum "$TMPFILE" | cut -d' ' -f1)"

echo "=== Uploading test file ==="
RESPONSE=$(curl -sf -X POST "$API/api/files" \
  -F "file=@$TMPFILE" \
  -F "metadata={\"filename\":\"test-document.txt\",\"size\":$(stat -c%s "$TMPFILE"),\"path\":\"/tmp/\",\"device_name\":\"test-device\",\"hash\":\"$HASH\",\"mtime\":\"$(date -Iseconds)\"}")

FILE_ID=$(echo "$RESPONSE" | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
echo "File created: $FILE_ID"
echo "$RESPONSE" | python3 -m json.tool

echo ""
echo "=== Polling for extraction completion ==="
for i in $(seq 1 30); do
  STATUS=$(curl -sf "$API/api/files/$FILE_ID" | python3 -c "import sys,json; print(json.load(sys.stdin)['status'])")
  echo "  status=$STATUS"
  if [ "$STATUS" = "ready" ]; then
    echo ""
    echo "=== File metadata ==="
    curl -sf "$API/api/files/$FILE_ID" | python3 -m json.tool
    echo ""
    echo "=== All tags ==="
    curl -sf "$API/api/tags" | python3 -m json.tool
    echo ""
    echo "=== All devices ==="
    curl -sf "$API/api/devices" | python3 -m json.tool
    rm -f "$TMPFILE"
    echo ""
    echo "Test passed!"
    exit 0
  fi
  if [ "$STATUS" = "failed" ]; then
    echo "ERROR: Extraction failed"
    rm -f "$TMPFILE"
    exit 1
  fi
  sleep 1
done

echo "ERROR: Extraction did not complete within 30s"
rm -f "$TMPFILE"
exit 1
